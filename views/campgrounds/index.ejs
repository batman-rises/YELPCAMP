<% layout('layouts/boilerplate') %>

<div class="container mt-4">

  <!-- ================= FILTER PANEL ================= -->
  <div class="filter-panel mb-4">
    <form method="GET" action="/campgrounds">
      <div class="row align-items-end g-3">

        <!-- Search -->
        <div class="col-md-5">
          <label class="form-label fw-semibold">Search</label>
          <input
            type="text"
            name="search"
            class="form-control"
            placeholder="Search by name or location"
            value="<%= search || '' %>"
          />
        </div>

        <!-- Min Price -->
        <div class="col-md-2">
          <label class="form-label fw-semibold">Min Price</label>
          <input
            type="number"
            name="minPrice"
            class="form-control"
            placeholder="₹"
            value="<%= minPrice || '' %>"
          />
        </div>

        <!-- Max Price -->
        <div class="col-md-2">
          <label class="form-label fw-semibold">Max Price</label>
          <input
            type="number"
            name="maxPrice"
            class="form-control"
            placeholder="₹"
            value="<%= maxPrice || '' %>"
          />
        </div>

        <!-- Buttons -->
        <div class="col-md-3 d-grid gap-2">
          <button class="btn btn-primary">Apply Filters</button>
          <a href="/campgrounds" class="btn btn-outline-secondary">
            Clear Filters
          </a>
        </div>

      </div>
    </form>
  </div>


  <!-- ================= MAP ================= -->
  <div id="cluster-map"></div>


  <!-- ================= PAGE HEADER ================= -->
  <div class="mt-4 mb-4">
    <h1 class="mb-1">Camping Sites Across India</h1>
    <p class="text-muted">
      Discover curated, peaceful camping locations inspired by India’s diverse landscapes.
    </p>
  </div>


  <!-- ================= EMPTY STATE ================= -->
  <% if (campgrounds.length === 0) { %>
    <div class="alert alert-light border text-center">
      <p class="mb-2">No campgrounds found.</p>
      <small class="text-muted">
        Try adjusting your search or price filters.
      </small>
    </div>
  <% } %>


  <!-- ================= CAMPGROUND CARDS ================= -->
  <% for (let campground of campgrounds) { %>

    <div class="card mb-4 campground-card">
      <div class="row g-0">

        <!-- Image -->
        <div class="col-md-4">
          <% if (campground.images && campground.images.length) { %>
            <img
              src="<%= campground.images[0].url %>"
              class="img-fluid h-100 w-100 object-cover"
              alt="<%= campground.title %>"
            >
          <% } else { %>
            <img
              src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee"
              class="img-fluid h-100 w-100 object-cover"
              alt="Campground image"
            >
          <% } %>
        </div>

        <!-- Content -->
        <div class="col-md-8">
          <div class="card-body d-flex flex-column h-100">

            <h5 class="card-title">
              <%= campground.title %>
            </h5>

            <p class="card-text text-muted small mb-2">
              <%= campground.location %>
            </p>

            <p class="card-text flex-grow-1">
              <%= campground.description %>
            </p>

            <div class="d-flex justify-content-between align-items-center mt-3">
              <span class="fw-semibold">
                ₹<%= campground.price %> / night
              </span>

              <a
                href="/campgrounds/<%= campground._id %>"
                class="btn btn-primary btn-sm"
              >
                View Details
              </a>
            </div>

          </div>
        </div>

      </div>
    </div>

  <% } %>

</div>


<!-- ================= MAP SCRIPT ================= -->
<script>
  const mapToken = '<%- process.env.MAPBOX_TOKEN %>';
  const campgrounds = <%- JSON.stringify(geoJSON) %>;
</script>

<script src="/javascripts/clusterMap.js"></script>
