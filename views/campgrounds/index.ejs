<% layout('layouts/boilerplate') %>

<div class="container mt-4">

  <!-- ================= FILTER PANEL ================= -->
  <div class="filter-panel mb-4">
    <form method="GET" action="/campgrounds">
      <div class="row align-items-end g-3">

        <!-- Search -->
        <div class="col-md-3">
          <label class="form-label fw-semibold">Search</label>
          <input
            type="text"
            name="search"
            class="form-control"
            placeholder="Search by name or location"
            value="<%= search || '' %>"
          />
        </div>

        <!-- Min Price -->
        <div class="col-md-2">
          <label class="form-label fw-semibold">Min Price</label>
          <input
            type="number"
            name="minPrice"
            class="form-control"
            placeholder="₹"
            value="<%= minPrice || '' %>"
          />
        </div>

        <!-- Max Price -->
        <div class="col-md-2">
          <label class="form-label fw-semibold">Max Price</label>
          <input
            type="number"
            name="maxPrice"
            class="form-control"
            placeholder="₹"
            value="<%= maxPrice || '' %>"
          />
        </div>

        <!-- Rating Filter -->
        <div class="col-md-2">
          <label class="form-label fw-semibold">Min Rating</label>
          <select name="rating" class="form-control">
            <option value="">Any</option>
            <option value="4.5" <%= rating == 4.5 ? 'selected' : '' %>>4.5+</option>
            <option value="4" <%= rating == 4 ? 'selected' : '' %>>4+</option>
            <option value="3.5" <%= rating == 3.5 ? 'selected' : '' %>>3.5+</option>
          </select>
        </div>

        <!-- Sort -->
        <div class="col-md-2">
          <label class="form-label fw-semibold">Sort</label>
          <select name="sort" class="form-control">
            <option value="">Default</option>
            <option value="price_asc" <%= sort === "price_asc" ? 'selected' : '' %>>
              Price ↑
            </option>
            <option value="price_desc" <%= sort === "price_desc" ? 'selected' : '' %>>
              Price ↓
            </option>
          </select>
        </div>

        <!-- Buttons -->
        <div class="col-md-1 d-grid">
          <button class="btn btn-primary">Go</button>
        </div>

      </div>
    </form>
  </div>


  <!-- ================= MAP ================= -->
  <div id="cluster-map"></div>


  <!-- ================= HEADER ================= -->
  <div class="mt-4 mb-4">
    <h1 class="mb-1">Camping Sites Across India</h1>
    <p class="text-muted">
      Discover curated, peaceful camping locations inspired by India’s diverse landscapes.
    </p>
  </div>


  <!-- ================= EMPTY STATE ================= -->
  <% if (campgrounds.length === 0) { %>
    <div class="alert alert-light border text-center">
      No campgrounds found. Try adjusting filters.
    </div>
  <% } %>


  <!-- ================= CARDS ================= -->
  <% for (let campground of campgrounds) { %>

    <div class="card mb-4 campground-card">
      <div class="row g-0">

        <!-- Image -->
        <div class="col-md-4">
          <img
            src="<%= campground.images?.[0]?.url || 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee' %>"
            class="img-fluid h-100 w-100 object-cover"
            alt="<%= campground.title %>"
          >
        </div>

        <!-- Content -->
        <div class="col-md-8">
          <div class="card-body d-flex flex-column h-100">

            <h5 class="card-title"><%= campground.title %></h5>

            <p class="text-muted small mb-2">
              <%= campground.location %>
            </p>

            <p class="flex-grow-1">
              <%= campground.description %>
            </p>

            <!-- Rating -->
            <p class="mb-2">
  ⭐ <strong>
    <%= campground.avgRating 
        ? campground.avgRating.toFixed(1) 
        : "New" %>
  </strong>
  <% if (campground.reviewCount > 0) { %>
    · <%= campground.reviewCount %> reviews
  <% } %>
</p>



            <div class="d-flex justify-content-between align-items-center">
              <span class="fw-semibold">
                ₹<%= campground.price %> / night
              </span>

              <a
                href="/campgrounds/<%= campground._id %>"
                class="btn btn-primary btn-sm"
              >
                View Details
              </a>
            </div>

          </div>
        </div>

      </div>
    </div>

  <% } %>

</div>


<script>
  const mapToken = '<%- process.env.MAPBOX_TOKEN %>';
  const campgrounds = <%- JSON.stringify(geoJSON || {}) %>;
</script>

<script src="/javascripts/clusterMap.js"></script>
